SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=absender@example.com
SMTP_PASSWORD=dein_passwort
SMTP_FROM=feuerwehr@example.com

# Kommagetrennte Liste der Kommandanten-Adressen (CC bei abgelaufenen Untersuchungen)
KOMMANDANTEN_CC=kommandant1@example.com,kommandant2@example.com

# Empfänger der Gesamtübersicht (alle Fälligkeiten sortiert, ein Mail für alle)
ZUSAMMENFASSUNG_AN=uebersicht@example.com,kommandant1@example.com

# Warnfrist in Tagen (Standard: 90 = 3 Monate)
WARN_DAYS=90

# Zu prüfende Prüfungstypen (kommagetrennt, Kurzbezeichnung aus MP-Feuer)
PRUEFUNGSTYPEN=G25
